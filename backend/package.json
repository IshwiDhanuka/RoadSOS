{
  "name": "roadsos-backend",
  "version": "1.0.0",
  "description": "RoadSoS Emergency Services Backend — Express + TypeScript + Firebase",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "tsx dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.3",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase-admin": "^13.8.0",
    "fuse.js": "^7.3.0",
    "helmet": "^8.0.0",
    "ngeohash": "^0.6.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5"
  }
}
